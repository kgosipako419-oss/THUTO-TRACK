DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL unset to use SQLite for local development.
# DATABASE_URL=postgres://user:password@localhost:5432/thutotrack

# Twilio account auth token. When set, the WhatsApp webhook validates
# the X-Twilio-Signature header on every request. REQUIRED in production.
# WHATSAPP_AUTH_TOKEN=your_twilio_auth_token
